# Test Environment Variables
# Copy this file to .env.test and fill in the values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Test User Credentials (for authenticated tests)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPass!2026

# JWT Token for RBAC tests (get from browser after login)
TEST_USER_TOKEN=your_jwt_token_here

# Gemini API Key (for AI tests)
VITE_GEMINI_API_KEY=your_gemini_key_here
