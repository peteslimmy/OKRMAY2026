# 4CORE Weekly OKR Platform - Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: OpenRouter API Key for AI features
# Get your key from https://openrouter.ai/
VITE_OPENROUTER_API_KEY=

# Optional: Local Ollama endpoint for on-prem AI
# Example: http://localhost:11434/api/chat
VITE_LOCAL_AI_URL=

# Development Mode
# Set to 'true' to enable simulation mode (bypasses auth for development)
VITE_SIMULATION_MODE=true
