    "test:env": "tsx tests/01-environment-verification.ts",
    "test:auth": "tsx tests/02-authentication.ts",
    "test:authz": "tsx tests/03-authorization.ts",
    "test:security": "tsx tests/04-api-security.ts",
    "test:headers": "tsx tests/07-security-headers.ts",
    "test:all": "npm run test && npm run test:e2e && npm run test:security",
    "test:load": "k6 run tests/load-test.js"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "@supabase/supabase-js": "^2.93.3",
    "@types/dompurify": "^3.0.5",
