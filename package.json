{
  "name": "4core-weekly-okr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3030 --host",
    "dev:keepalive": "npx vite --port 3030 --host",
    "start": "npx vite --port 3030 --host",
    "build": "vite build",
    "build:verify": "vite build && node scripts/verify-production-build.js",
    "preview": "vite preview",
    "seed": "tsx scripts/seed.ts",
    "seed:sql": "psql $SUPABASE_DATABASE_URL -f supabase/sql/seed-2025-full.sql",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cypress open",
    "test:security:lint": "eslint . --ext .ts,.tsx",
    "test:env": "tsx tests/01-environment-verification.ts",
    "test:auth": "tsx tests/02-authentication.ts",
    "test:authz": "tsx tests/03-authorization.ts",
    "test:security": "tsx tests/04-api-security.ts",
    "test:headers": "tsx tests/07-security-headers.ts",
    "test:all": "npm run test && npm run test:e2e && npm run test:security",
    "test:load": "k6 run tests/load-test.js",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "test:pw:headed": "playwright test --headed",
    "test:pw:chromium": "playwright test --project=chromium",
    "test:pw:firefox": "playwright test --project=firefox",
    "test:pw:webkit": "playwright test --project=webkit",
    "test:pw:nav": "playwright test tests/e2e/navigation",
    "test:pw:auth": "playwright test tests/e2e/auth",
    "test:pw:features": "playwright test tests/e2e/features",
    "test:pw:components": "playwright test tests/e2e/components",
    "test:pw:regression": "playwright test tests/e2e/regression",
    "test:pw:visual": "playwright test tests/e2e/components/visual.spec.ts",
    "test:pw:api": "playwright test tests/e2e/features/api.spec.ts",
    "test:pw:a11y": "playwright test tests/e2e/features/accessibility.spec.ts",
    "test:pw:report": "playwright show-report",
    "test:pw:install": "playwright install chromium --with-deps",
    "test:pw:ui-styling": "playwright test tests/e2e/components/ui-styling.spec.ts",
    "test:pw:api-full": "playwright test tests/e2e/api/supabase-api.spec.ts",
    "test:pw:all": "playwright test",
    "test:pw:ci": "playwright test --reporter=html,json"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "@supabase/supabase-js": "^2.93.3",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.561.0",
    "openai": "^6.34.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "react-joyride": "^3.0.2",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "ai": "^6.0.169",
    "autoprefixer": "^10.5.0",
    "cypress": "^13.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^1.7.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "netlify-cli": "^26.0.1",
    "ollama-ai-provider-v2": "^3.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
