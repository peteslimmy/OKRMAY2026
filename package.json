    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "cypress": "^13.15.0",
    "eslint-plugin-security": "^1.7.1",
    "@types/jest": "^29.5.12",
    "jest-environment-jsdom": "^29.7.0"
  }
